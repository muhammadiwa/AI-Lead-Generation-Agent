# Lead Gen Agent — Backend Configuration
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/leadgen
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Data Collection API Keys
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
GITHUB_TOKEN=
CRUNCHBASE_API_KEY=
HUNTER_API_KEY=
CLEARBIT_API_KEY=
APOLLO_API_KEY=
FIRECRAWL_API_KEY=

# Social Media API Keys
TWITTER_API_KEY=
TWITTER_API_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
FACEBOOK_ACCESS_TOKEN=

# Email (Resend)
RESEND_API_KEY=

# Security
SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App Settings
LOG_LEVEL=INFO
CORS_ORIGINS=*
ENVIRONMENT=development